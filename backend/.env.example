PORT=5000
NODE_ENV=development

# Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/tracknow

# MongoDB Atlas (replace USER, PASSWORD, CLUSTER)
# If password has special characters (@ # : /), URL-encode them first.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tracknow?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_secret

# Admin seed (npm run seed:admin) — optional overrides
# ADMIN_PHONE=7373144198
# ADMIN_PASSWORD=your_admin_password

# Public links (driver rental, user registration) — client app URL, no trailing slash
# FRONTEND_CLIENT_URL=https://tracknow-client.netlify.app

# Production — comma-separated frontend URLs (Netlify or other hosts)
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://tracknow-client.netlify.app,https://tracknow-admin.netlify.app

# Monthly backup (optional; set false on Render — disk is ephemeral)
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_MONTHS=12
