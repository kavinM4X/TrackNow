PORT=5000
NODE_ENV=development

# Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/tracknow

# MongoDB Atlas (replace USER, PASSWORD, CLUSTER)
# If password has special characters (@ # : /), URL-encode them first.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tracknow?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_secret

# Render / production — comma-separated frontend URLs
# CORS_ORIGIN=https://your-admin.onrender.com,https://your-client.onrender.com

# Monthly backup (optional; set false on Render — disk is ephemeral)
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_MONTHS=12
